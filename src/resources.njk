---
layout: layouts/base.njk
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "/{{ locale }}/resources/"
pageTitle: "Resources"
---
{%- set t = i18n[locale] -%}

<div class="container py-5">
  <h1 class="bwc-section-title mb-2">{{ t.resources_title }}</h1>
  <p class="bwc-section-lead mb-5">{{ t.resources_lead }}</p>
  <div class="row gy-4">
    <div class="col-12 col-md-6 col-lg-4">
      <div class="bwc-card h-100">
        <div class="bwc-card-icon"><i class="fa-solid fa-arrows-left-right"></i></div>
        <h2 class="h5 mb-3">{{ t.resources_exchanges }}</h2>
        <ul class="list-unstyled mb-0">
          <li class="mb-2"><a href="https://komodoplatform.com/en/" target="_blank" rel="noopener" class="d-flex align-items-center gap-2"><i class="fa-solid fa-rotate fa-fw"></i> Komodo DEX</a></li>
          <li class="mb-2"><a href="https://dex.gleec.com/" target="_blank" rel="noopener" class="d-flex align-items-center gap-2"><i class="fa-solid fa-rotate fa-fw"></i> Gleec DEX</a></li>
        </ul>
      </div>
    </div>
    <div class="col-12 col-md-6 col-lg-4">
      <div class="bwc-card h-100">
        <div class="bwc-card-icon"><i class="fa-solid fa-magnifying-glass"></i></div>
        <h2 class="h5 mb-3">{{ t.resources_explorers }}</h2>
        <ul class="list-unstyled mb-0">
          <li class="mb-2"><a href="https://explorer.dpowcore.org" target="_blank" rel="noopener" class="d-flex align-items-center gap-2"><i class="fa-solid fa-cube fa-fw"></i> explorer.dpowcore.org</a></li>
        </ul>
      </div>
    </div>
    <div class="col-12 col-md-6 col-lg-4">
      <div class="bwc-card h-100">
        <div class="bwc-card-icon"><i class="fa-solid fa-chart-bar"></i></div>
        <h2 class="h5 mb-3">{{ t.resources_coin_info }}</h2>
        <ul class="list-unstyled mb-0">
          <li class="mb-2"><a href="https://coinpaprika.com/coin/dpc-dpowcoin" target="_blank" rel="noopener" class="d-flex align-items-center gap-2"><i class="fa-solid fa-circle-dollar-to-slot fa-fw"></i>CoinPaprika</a></li>
        </ul>
      </div>
    </div>
    <div class="col-12 col-md-6 col-lg-4">
      <div class="bwc-card h-100">
        <div class="bwc-card-icon"><i class="fa-brands fa-telegram"></i></div>
        <h2 class="h5 mb-3">{{ t.resources_tg_groups }}</h2>
        <ul class="list-unstyled mb-0">
          <li class="mb-2"><a href="https://t.me/dpowcoin" target="_blank" rel="noopener" class="d-flex align-items-center gap-2"><i class="fa-brands fa-telegram fa-fw"></i> Global</a></li>
          <li class="mb-2"><a href="https://t.me/dpowcore" target="_blank" rel="noopener" class="d-flex align-items-center gap-2"><i class="fa-brands fa-telegram fa-fw"></i> DEV</a></li>
          <li class="mb-2"><a href="https://t.me/dpowcoin_cn" target="_blank" rel="noopener" class="d-flex align-items-center gap-2"><i class="fa-brands fa-telegram fa-fw"></i> Chinese</a></li>
        </ul>
      </div>
    </div>
    <div class="col-12 col-md-6 col-lg-4">
      <div class="bwc-card h-100">
        <div class="bwc-card-icon"><i class="fa-solid fa-newspaper"></i></div>
        <h2 class="h5 mb-3">{{ t.resources_tg_news }}</h2>
        <ul class="list-unstyled mb-0">
          <li class="mb-2"><a href="https://t.me/dpowcoin_news" target="_blank" rel="noopener" class="d-flex align-items-center gap-2"><i class="fa-brands fa-telegram fa-fw"></i> Global</a></li>
          <li class="mb-2"><a href="https://t.me/dpowcoin_news_cn" target="_blank" rel="noopener" class="d-flex align-items-center gap-2"><i class="fa-brands fa-telegram fa-fw"></i> China</a></li>
        </ul>
      </div>
    </div>
    <div class="col-12 col-md-6 col-lg-4">
      <div class="bwc-card h-100">
        <div class="bwc-card-icon"><i class="fa-solid fa-users"></i></div>
        <h2 class="h5 mb-3">{{ t.resources_community }}</h2>
        <ul class="list-unstyled mb-0">
          <li class="mb-2"><a href="https://github.com/dpowcore-project" target="_blank" rel="noopener" class="d-flex align-items-center gap-2"><i class="fa-brands fa-github fa-fw"></i> GitHub</a></li>
          <li class="mb-2"><a href="https://discord.gg/b9zkzAgUpH" target="_blank" rel="noopener" class="d-flex align-items-center gap-2"><i class="fa-brands fa-discord fa-fw"></i> Discord</a></li>
          <li class="mb-2"><a href="https://twitter.com/dpowcoin" target="_blank" rel="noopener" class="d-flex align-items-center gap-2"><i class="fa-brands fa-x-twitter fa-fw"></i> Twitter / X</a></li>
          <li class="mb-2"><a href="https://bitcointalk.org/index.php?topic=5493459.0" target="_blank" rel="noopener" class="d-flex align-items-center gap-2"><i class="fa-brands fa-bitcoin fa-fw"></i> Bitcointalk</a></li>
        </ul>
      </div>
    </div>
  </div>
</div>
