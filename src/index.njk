---
layout: layouts/base.njk
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "/{{ locale }}/"
pageTitle: "Home"
---
{%- set t = i18n[locale] -%}

<section class="bwc-hero">
  <div class="bwc-hero-grid"></div>
  <div class="container position-relative">
    <div class="row justify-content-center text-center">
      <div class="col-12 col-lg-8">
        <div class="mb-4">
          <span class="bwc-badge-latest px-3 py-1">
            <i class="fa-solid fa-microchip me-1"></i>Argon2id PoW
          </span>
        </div>
        <h1 class="bwc-tagline mb-4">
          {{ t.hero_tagline | replace("Argon2id", '<span class="bwc-accent-text">Argon2id</span>') | safe }}
        </h1>
        <p class="bwc-hero-desc mx-auto mb-5">{{ t.hero_description }}</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
          <a href="/{{ locale }}/wallets/full-node/" class="btn btn-bwc-primary">
            <i class="fa-solid fa-download me-2"></i>{{ t.hero_download }}
          </a>
          <a href="{{ site.github }}" class="btn btn-bwc-secondary" target="_blank" rel="noopener">
            <i class="fa-brands fa-github me-2"></i>{{ t.hero_source }}
          </a>
          <a href="/{{ locale }}/about/" class="btn btn-bwc-secondary">{{ t.hero_learn }}</a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="bwc-section">
  <div class="container">
    <div class="row gy-4">
      <div class="col-12 col-md-4">
        <div class="bwc-card h-100">
          <div class="bwc-card-icon"><i class="fa-solid fa-shield-halved"></i></div>
          <h3 class="h5 mb-2">{{ t.home_feat1_title }}</h3>
          <p class="text-secondary small mb-0">{{ t.home_feat1_body }}</p>
        </div>
      </div>
      <div class="col-12 col-md-4">
        <div class="bwc-card h-100">
          <div class="bwc-card-icon"><i class="fa-solid fa-code"></i></div>
          <h3 class="h5 mb-2">{{ t.home_feat2_title }}</h3>
          <p class="text-secondary small mb-0">{{ t.home_feat2_body }}</p>
        </div>
      </div>
      <div class="col-12 col-md-4">
        <div class="bwc-card h-100">
          <div class="bwc-card-icon"><i class="fa-solid fa-circle-check"></i></div>
          <h3 class="h5 mb-2">{{ t.home_feat3_title }}</h3>
          <p class="text-secondary small mb-0">{{ t.home_feat3_body }}</p>
        </div>
      </div>
    </div>
  </div>
</section>

{# ── Coin Specification ── #}
<section class="bwc-section bwc-section-flush">
  <div class="container">

    <div class="d-flex flex-wrap align-items-center gap-3 mb-4">
      <div>
        <h2 class="bwc-section-title mb-1">{{ t.spec_title }}</h2>
        <p class="bwc-section-lead mb-0">{{ t.spec_subtitle }}</p>
      </div>
      <div class="ms-auto">
        <span class="bwc-ticker-badge">BTE</span>
      </div>
    </div>

    {# Economics row #}
    <div class="row gy-3 mb-4">
      <div class="col-6 col-lg-3">
        <div class="bwc-spec-stat">
          <div class="bwc-spec-stat-label">{{ t.spec_max_supply }}</div>
          <div class="bwc-spec-stat-value">42 000 000</div>
          <div class="bwc-spec-stat-sub">BTE</div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="bwc-spec-stat">
          <div class="bwc-spec-stat-label">{{ t.spec_block_reward }}</div>
          <div class="bwc-spec-stat-value">50 <small>BTE</small></div>
          <div class="bwc-spec-stat-sub">{{ t.spec_halving }}: 420 000 {{ t.spec_blocks }}</div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="bwc-spec-stat">
          <div class="bwc-spec-stat-label">{{ t.spec_block_time }}</div>
          <div class="bwc-spec-stat-value">5 <small>min</small></div>
          <div class="bwc-spec-stat-sub">300 s</div>
        </div>
      </div>
      <div class="col-6 col-lg-3">
        <div class="bwc-spec-stat">
          <div class="bwc-spec-stat-label">{{ t.spec_maturity }}</div>
          <div class="bwc-spec-stat-value">100</div>
          <div class="bwc-spec-stat-sub">{{ t.spec_blocks }}</div>
        </div>
      </div>
    </div>

    {# PoW + Difficulty #}
    <div class="row gy-4 mb-4">
      <div class="col-12 col-md-6">
        <div class="bwc-card h-100">
          <div class="bwc-spec-sub-title">{{ t.spec_pow_title }}</div>
          <div class="bwc-spec-row">
            <span class="bwc-spec-key">{{ t.spec_pow_algo }}</span>
            <span class="bwc-spec-val bwc-spec-accent">Argon2id</span>
          </div>
          <div class="bwc-spec-row">
            <span class="bwc-spec-key">{{ t.spec_pow_params }}</span>
            <span class="bwc-spec-val">m=1024 · t=3 · p=1</span>
          </div>
          <div class="bwc-spec-row">
            <span class="bwc-spec-key">{{ t.spec_pow_model }}</span>
            <span class="bwc-spec-val">{{ t.spec_pow_model_val }}</span>
          </div>
          <div class="bwc-spec-note">
            <p class="bwc-text-muted-sm mb-0">{{ t.spec_pow_note }}</p>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6">
        <div class="bwc-card h-100">
          <div class="bwc-spec-sub-title">{{ t.spec_diff_title }}</div>
          <div class="bwc-spec-row">
            <span class="bwc-spec-key">{{ t.spec_diff_type }}</span>
            <span class="bwc-spec-val bwc-spec-accent">LWMA</span>
          </div>
          <div class="bwc-spec-row">
            <span class="bwc-spec-key">{{ t.spec_diff_window }}</span>
            <span class="bwc-spec-val">576 {{ t.spec_blocks }}</span>
          </div>
          <div class="bwc-spec-row">
            <span class="bwc-spec-key">{{ t.spec_diff_period }}</span>
            <span class="bwc-spec-val">~2 {{ t.spec_days }}</span>
          </div>
          <div class="bwc-spec-row">
            <span class="bwc-spec-key">{{ t.spec_diff_retarget }}</span>
            <span class="bwc-spec-val bwc-spec-accent">{{ t.spec_diff_retarget_val }}</span>
          </div>
        </div>
      </div>
    </div>

    {# Address Formats + Network #}
    <div class="row gy-4 mb-4">
      <div class="col-12 col-md-6">
        <div class="bwc-card h-100">
          <div class="bwc-spec-sub-title">{{ t.spec_addr_title }}</div>
          <div class="bwc-spec-row">
            <span class="bwc-spec-key">P2PKH</span>
            <span class="bwc-spec-val">
              <span class="bwc-spec-accent bwc-spec-addr-prefix">E</span><span class="bwc-spec-addr-ellipsis">…</span>
              <span class="bwc-spec-addr-dec">dec 33</span>
              <span class="bwc-spec-addr-tag">0x21</span>
            </span>
          </div>
          <div class="bwc-spec-row">
            <span class="bwc-spec-key">P2SH</span>
            <span class="bwc-spec-val">
              <span class="bwc-spec-accent bwc-spec-addr-prefix">D</span><span class="bwc-spec-addr-ellipsis">…</span>
              <span class="bwc-spec-addr-dec">dec 30</span>
              <span class="bwc-spec-addr-tag">0x1E</span>
            </span>
          </div>
          <div class="bwc-spec-row">
            <span class="bwc-spec-key">Bech32</span>
            <span class="bwc-spec-val">
              <span class="bwc-spec-accent">web</span>1q<span class="bwc-spec-addr-ellipsis">…</span>
              <span class="bwc-spec-addr-tag">SegWit</span>
            </span>
          </div>
          <div class="bwc-spec-row">
            <span class="bwc-spec-key">Bech32m</span>
            <span class="bwc-spec-val">
              <span class="bwc-spec-accent">web</span>1p<span class="bwc-spec-addr-ellipsis">…</span>
              <span class="bwc-spec-addr-tag">Taproot</span>
            </span>
          </div>
          <div class="bwc-spec-note">
            <p class="bwc-text-muted-sm mb-0">{{ t.spec_addr_note }}</p>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6">
        <div class="bwc-card h-100">
          <div class="bwc-spec-sub-title">{{ t.spec_net_title }}</div>
          <div class="bwc-spec-row">
            <span class="bwc-spec-key">P2P Port</span>
            <span class="bwc-spec-val bwc-spec-accent">26333</span>
          </div>
          <div class="bwc-spec-row">
            <span class="bwc-spec-key">RPC Port</span>
            <span class="bwc-spec-val bwc-spec-accent">26332</span>
          </div>
          <div class="bwc-spec-row">
            <span class="bwc-spec-key">{{ t.spec_net_magic }}</span>
            <span class="bwc-spec-val">0xfeaed5ca</span>
          </div>
          <div class="bwc-spec-row">
            <span class="bwc-spec-key">BIP-324 Salt</span>
            <span class="bwc-spec-val">bitweb_v2_shared_secret</span>
          </div>
          <div class="bwc-spec-row">
            <span class="bwc-spec-key">{{ t.spec_net_bips }}</span>
            <span class="bwc-spec-val bwc-spec-accent">{{ t.spec_net_bips_val }}</span>
          </div>
        </div>
      </div>
    </div>

    {# Genesis + PoW Limit #}
    <div class="row gy-4">
      <div class="col-12 col-md-6">
        <div class="bwc-card h-100">
          <div class="bwc-spec-sub-title">{{ t.spec_genesis_title }}</div>
          <div class="bwc-hash-display">
            <span class="bwc-hash-body">111692c1</span><span class="bwc-hash-body">b9b390c4</span><span class="bwc-hash-body">07ab74d7</span><span class="bwc-hash-body">f924d4fa</span><span class="bwc-hash-body">0f758997</span><span class="bwc-hash-body">4ab61af9</span><span class="bwc-hash-body">6392feca</span><span class="bwc-hash-body">11f209e6</span>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6">
        <div class="bwc-card h-100">
          <div class="bwc-spec-sub-title">{{ t.spec_powlimit_title }}</div>
          <div class="bwc-hash-display">
            <span class="bwc-hash-zeros">000f</span><span class="bwc-hash-body">ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff</span>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<section class="bwc-section bwc-section-flush">
  <div class="container">
    <div class="mb-5">
      <h2 class="bwc-section-title mb-1">{{ t.vest_title }}</h2>
      <p class="bwc-section-lead mb-0">{{ t.vest_subtitle }}</p>
    </div>

    {# Row 1: Background + Vesting protection #}
    <div class="row gy-4 mb-4">
      <div class="col-12 col-md-6">
        <div class="bwc-card h-100">
          <div class="bwc-spec-sub-title">{{ t.vest_launch_title }}</div>
          <p class="bwc-vest-text mb-0">{{ t.vest_launch_body }}</p>
        </div>
      </div>
      <div class="col-12 col-md-6">
        <div class="bwc-card h-100">
          <div class="bwc-spec-sub-title">{{ t.vest_protect_title }}</div>
          <p class="bwc-vest-text mb-0">{{ t.vest_protect_body }}</p>
        </div>
      </div>
    </div>

    {# Row 2: Key blocks #}
    <div class="bwc-card mb-4">
      <div class="bwc-spec-sub-title mb-3">{{ t.vest_blocks_title }}</div>
      <div class="row gy-3">
        <div class="col-12 col-md-4">
          <div class="bwc-vest-milestone bwc-vest-milestone--start">
            <div class="bwc-vest-milestone-label">{{ t.vest_block1_label }}</div>
            <div class="bwc-vest-milestone-val">{{ t.vest_block1_val }}</div>
            <div class="bwc-vest-milestone-desc">{{ t.vest_block1_desc }}</div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="bwc-vest-milestone bwc-vest-milestone--end">
            <div class="bwc-vest-milestone-label">{{ t.vest_block2_label }}</div>
            <div class="bwc-vest-milestone-val">{{ t.vest_block2_val }}</div>
            <div class="bwc-vest-milestone-desc">{{ t.vest_block2_desc }}</div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="bwc-vest-milestone bwc-vest-milestone--unlock">
            <div class="bwc-vest-milestone-label">{{ t.vest_block3_label }}</div>
            <div class="bwc-vest-milestone-val">{{ t.vest_block3_val }}</div>
            <div class="bwc-vest-milestone-desc">{{ t.vest_block3_desc }}</div>
          </div>
        </div>
      </div>
    </div>

    {# Row 3: Miner note + Pool warning #}
    <div class="row gy-4">
      <div class="col-12 col-md-6">
        <div class="bwc-vest-note bwc-vest-note--miner">
          <div class="bwc-vest-note-icon"><i class="fa-solid fa-pickaxe"></i></div>
          <div>
            <div class="bwc-spec-sub-title">{{ t.vest_miner_title }}</div>
            <p class="bwc-vest-text mb-0">{{ t.vest_miner_body }}</p>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6">
        <div class="bwc-vest-note bwc-vest-note--pool">
          <div class="bwc-vest-note-icon"><i class="fa-solid fa-triangle-exclamation"></i></div>
          <div>
            <div class="bwc-spec-sub-title">{{ t.vest_pool_title }}</div>
            <p class="bwc-vest-text">{{ t.vest_pool_body }}</p>
            <span class="bwc-vest-badge">{{ t.vest_pool_badge }}</span>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<section class="bwc-section bwc-section-flush">
  <div class="container">
    <div class="bwc-card d-flex flex-wrap align-items-center gap-3">
      <div>
        <div class="text-secondary small mb-1">{{ t.home_latest_label }}</div>
        <div class="fw-bold" id="bwc-latest-ver">—</div>
      </div>
      <div class="ms-auto d-flex gap-2 flex-wrap">
        <a href="/{{ locale }}/wallets/full-node/" class="btn btn-bwc-primary btn-sm">
          <i class="fa-solid fa-download me-1"></i>{{ t.home_download }}
        </a>
        <a href="{{ site.github }}/releases" class="btn btn-bwc-secondary btn-sm" target="_blank" rel="noopener">
          {{ t.home_release_notes }}
        </a>
      </div>
    </div>
  </div>
</section>

<section class="bwc-section bwc-section-flush">
  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="bwc-section-title mb-0">{{ t.home_latest_news }}</h2>
      <a href="/{{ locale }}/blog/" class="small">{{ t.read_more }}</a>
    </div>
    {%- set localeMap = {"en": "En", "ru": "Ru"} -%}
    {%- set blogKey = "blog" + localeMap[locale] -%}
    {%- if collections[blogKey] and collections[blogKey].length -%}
      {%- set posts = collections[blogKey] -%}
    {%- else -%}
      {%- set posts = collections.blogEn -%}
    {%- endif -%}
    {% if posts and posts.length %}
    <div class="row gy-3">
      {% for post in posts | slice(0, 3) %}
      <div class="col-12 col-md-4">
        <div class="bwc-post-card">
          <div class="bwc-post-date mb-2">{{ post.date | dateShort }}</div>
          <h3 class="bwc-post-title"><a href="{{ post.url }}" class="text-decoration-none text-white">{{ post.data.title }}</a></h3>
          <p class="text-secondary small mb-2">{{ post.data.summary | default("") }}</p>
          <a href="{{ post.url }}" class="small">{{ t.read_more }}</a>
        </div>
      </div>
      {% endfor %}
    </div>
    {% else %}
    <div class="bwc-placeholder text-center py-4">
      <i class="fa-solid fa-newspaper fs-3 d-block mb-2 opacity-50"></i>
      <p class="mb-0">{{ t.news_empty }}</p>
    </div>
    {% endif %}
  </div>
</section>

{% block scripts %}<script src="/static/js/home.js"
  integrity="{{ 'js/home.js' | sri }}" crossorigin="anonymous"></script>{% endblock %}
