<!DOCTYPE html>
<html lang="{{ locale | default('en') }}" data-bs-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ pageDescription | default(site.description) }}">
  <meta property="og:title" content="{{ pageTitle | default(site.title) }}">
  <meta property="og:description" content="{{ pageDescription | default(site.description) }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary">
  <title>{% if pageTitle %}{{ pageTitle }} — {% endif %}{{ site.title }}</title>

  <!-- https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.8/css/bootstrap.min.css -->
  <link rel="stylesheet" href="/static/css/bootstrap.min.css"
    integrity="{{ 'css/bootstrap.min.css' | sri }}" crossorigin="anonymous">
  <!-- https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css -->
  <link rel="stylesheet" href="/static/css/all.min.css"
    integrity="{{ 'css/all.min.css' | sri }}" crossorigin="anonymous">
  <link rel="stylesheet" href="/static/css/custom.css"
    integrity="{{ 'css/custom.css' | sri }}" crossorigin="anonymous">

  <link rel="icon" href="/static/favicon.ico" sizes="16x16 32x32 48x48">
  <link rel="icon" href="/static/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/static/apple-touch-icon.png">

  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  {%- if not noAlternate %}
    {%- for altLang in site.locales %}
      {%- if altLang != locale %}
  <link rel="alternate" hreflang="{{ altLang }}" href="{{ site.url }}/{{ altLang }}{{ page.url | replace('/' + locale + '/', '/') }}">
      {%- endif %}
    {%- endfor %}
  {%- endif %}
</head>
<body>

{% include "partials/nav.njk" %}
<main>{{ content | safe }}</main>
{% include "partials/footer.njk" %}

<!-- https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.8/js/bootstrap.bundle.min.js -->
<script src="/static/js/bootstrap.bundle.min.js"
  integrity="{{ 'js/bootstrap.bundle.min.js' | sri }}" crossorigin="anonymous"></script>
<script src="/static/js/theme.js"
  integrity="{{ 'js/theme.js' | sri }}" crossorigin="anonymous"></script>
{% block scripts %}{% endblock %}
</body>
</html>
