{%- set l = locale | default('en') -%}
{%- for lang in site.locales -%}
  {%- if ('/' + lang + '/') in page.url %}{%- set l = lang -%}{%- endif -%}
{%- endfor -%}
{%- set t = i18n[l] -%}

<footer class="bwc-footer mt-auto py-5">
  <div class="container">
    <div class="row gy-4">

      <div class="col-12 col-md-4">
        <div class="d-flex align-items-center gap-2 mb-3">
          <img src="/static/img/logo.svg" alt="{{ site.title }}" width="28" height="28"
               class="bwc-logo">
          <span class="fw-bold fs-5">{{ site.title }}</span>
        </div>
        <p class="text-secondary small">{{ t.footer_rights }}</p>
      </div>

      <div class="col-6 col-md-2">
        <h6 class="text-uppercase text-secondary small fw-semibold mb-3">{{ t.footer_project }}</h6>
        <ul class="list-unstyled">
          <li><a href="/{{ l }}/about/" class="footer-link">{{ t.nav_about }}</a></li>
          <li><a href="/{{ l }}/wallets/full-node/" class="footer-link">{{ t.nav_wallets_fullnode }}</a></li>
          <li><a href="/{{ l }}/blog/" class="footer-link">{{ t.nav_news }}</a></li>
          <li><a href="/{{ l }}/resources/" class="footer-link">{{ t.nav_resources }}</a></li>
          <li><a href="/{{ l }}/brand/" class="footer-link">{{ t.nav_brand }}</a></li>
        </ul>
      </div>

      <div class="col-6 col-md-2">
        <h6 class="text-uppercase text-secondary small fw-semibold mb-3">{{ t.footer_developers }}</h6>
        <ul class="list-unstyled">
          <li><a href="/{{ l }}/development/" class="footer-link">{{ t.nav_contribute }}</a></li>
          <li><a href="/{{ l }}/development/rpc/" class="footer-link">{{ t.nav_rpc }}</a></li>
          <li><a href="/{{ l }}/whitepaper/" class="footer-link">{{ t.nav_whitepaper }}</a></li>
          <li><a href="{{ site.github }}" class="footer-link" target="_blank" rel="noopener">
            <i class="fa-brands fa-github me-1"></i>{{ t.footer_github }}
          </a></li>
          <li><a href="{{ site.guix_sigs }}" class="footer-link" target="_blank" rel="noopener">
            {{ t.footer_guix_sigs }}
          </a></li>
        </ul>
      </div>

      <div class="col-12 col-md-4">
        <h6 class="text-uppercase text-secondary small fw-semibold mb-3">{{ t.footer_security }}</h6>
        <p class="text-secondary small mb-1">{{ t.footer_gpg_label }}</p>
        <code class="bwc-fingerprint">{{ site.gpg_fingerprint }}</code>
        <div class="mt-2">
          <a href="{{ site.gpg_key_url }}" target="_blank" rel="noopener" class="footer-link small">
            <i class="fa-solid fa-shield-halved me-1"></i>{{ t.footer_verify_key }}
          </a>
        </div>
      </div>

    </div>

    <hr class="border-secondary mt-4 mb-3">

    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 text-secondary small">
      <span>&copy; {{ site.title }} contributors</span>
      <a href="{{ site.github_license }}" class="footer-link" target="_blank" rel="noopener">{{ t.footer_license }}</a>
    </div>
  </div>
</footer>
