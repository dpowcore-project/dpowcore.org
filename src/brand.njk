---
layout: layouts/base.njk
pagination:
  data: locales
  size: 1
  alias: locale
permalink: "/{{ locale }}/brand/"
pageTitle: "Brand"
---
{%- set t = i18n[locale] -%}

<div class="container py-5">
  <h1 class="bwc-section-title mb-2">{{ t.brand_title }}</h1>
  <p class="bwc-section-lead mb-5">{{ t.brand_lead }}</p>

  <div class="bwc-card mb-5">
    <h2 class="h5 mb-2">{{ t.brand_usage }}</h2>
    <p class="text-secondary small mb-0">{{ t.brand_usage_body }}</p>
  </div>

  <h2 class="h5 mb-3">{{ t.brand_logo_color }}</h2>
  <div class="row gy-4 mb-5">

    <div class="col-12 col-md-4">
      <div class="bwc-card h-100 d-flex flex-column align-items-center py-4">
        <img src="/static/img/bitweb.svg" alt="Bitweb Core color logo" width="96" height="96">
        <div class="mt-3 text-secondary small mb-1">SVG</div>
        <p class="text-secondary small text-center mb-3">{{ t.brand_svg_note }}</p>
        <a href="/static/img/bitweb.svg" download class="btn btn-bwc-secondary btn-sm">
          <i class="fa-solid fa-download me-1"></i>{{ t.brand_download }} SVG
        </a>
      </div>
    </div>

    {%- for size in ["128", "256", "512", "1024"] %}
    <div class="col-6 col-md-2">
      <div class="bwc-card h-100 d-flex flex-column align-items-center py-4">
        <img src="/static/img/bitweb{{ size }}.png" alt="Bitweb Core {{ size }}px" width="56" height="56">
        <div class="mt-3 text-secondary small mb-3">{{ size }}×{{ size }} PNG</div>
        <a href="/static/img/bitweb{{ size }}.png" download class="btn btn-bwc-secondary btn-sm">
          <i class="fa-solid fa-download me-1"></i>{{ t.brand_download }}
        </a>
      </div>
    </div>
    {%- endfor %}

  </div>

  <h2 class="h5 mb-3">{{ t.brand_logo_black }}</h2>
  <div class="row gy-4">

    <div class="col-12 col-md-4">
      <div class="bwc-card h-100 d-flex flex-column align-items-center py-4">
        <img src="/static/img/bitweb_black.svg" alt="Bitweb Core black logo" width="96" height="96">
        <div class="mt-3 text-secondary small mb-1">SVG</div>
        <p class="text-secondary small text-center mb-3">{{ t.brand_svg_note }}</p>
        <a href="/static/img/bitweb_black.svg" download class="btn btn-bwc-secondary btn-sm">
          <i class="fa-solid fa-download me-1"></i>{{ t.brand_download }} SVG
        </a>
      </div>
    </div>

    {%- for size in ["128", "256", "512", "1024"] %}
    <div class="col-6 col-md-2">
      <div class="bwc-card h-100 d-flex flex-column align-items-center py-4">
        <img src="/static/img/bitweb_black{{ size }}.png" alt="Bitweb Core black {{ size }}px" width="56" height="56">
        <div class="mt-3 text-secondary small mb-3">{{ size }}×{{ size }} PNG</div>
        <a href="/static/img/bitweb_black{{ size }}.png" download class="btn btn-bwc-secondary btn-sm">
          <i class="fa-solid fa-download me-1"></i>{{ t.brand_download }}
        </a>
      </div>
    </div>
    {%- endfor %}

  </div>

</div>
